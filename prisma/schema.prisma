generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum VolunteerRole {
  GUITARIST
  PIANIST
  AUX_KEYS
  DRUMMER
  LEAD_VOCALIST
  BGVS
  BASSIST
  SOUND_TECH
  USHER
  GREETER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
}

enum Pitch {
  C
  C_SHARP   @map("C#")
  D_FLAT    @map("Db")
  D
  D_SHARP   @map("D#")
  E_FLAT    @map("Eb")
  E
  F
  F_SHARP   @map("F#")
  G_FLAT    @map("Gb")
  G
  G_SHARP   @map("G#")
  A_FLAT    @map("Ab")
  A
  A_SHARP   @map("A#")
  B_FLAT    @map("Bb")
  B
}

enum KeyQuality {
  MAJOR
  MINOR
}



model User {
  id        String @id @default(uuid())
  clerkId   String @unique
  email     String @unique
  firstName String
  lastName  String
  phoneNumber String
  userImageUrl String?

  memberships Membership[]
  sentInvitations Invitation[] 
  eventsCreated Event[]
  
  assignedEvents EventAssignment[] @relation("assignedUser")
  createdAssignments EventAssignment[] @relation("assignedBy")

  authoredMessages Message[] @relation("authoredMessages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  description String

  memberships Membership[]
  invitations Invitation[]
  serviceTypes ServiceType[]
  events Event[]
  eventAssignments EventAssignment[]
  songs Song[]
  messages Message[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Membership {
  id          String   @id @default(uuid())
  role OrgRole @default(MEMBER)
  volunteerRoles VolunteerRole[]

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@index([organizationId, role])
}

model Invitation {
  id String @id @default(uuid())
  email String 
  token String @unique @default(uuid())
  status InvitationStatus @default(PENDING)
  volunteerRoles VolunteerRole[]
  expiresAt DateTime

  invitedById String
  invitedBy User @relation(fields: [invitedById], references: [id])

  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, organizationId])
  @@index([token])
  @@index([email])
  @@index([organizationId])

}

model ServiceType {
  id String @id @default(uuid())
  name String
  color String

  events Event[] 

  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([name, organizationId])
}

model Event {
  id String @id @default(uuid())
  name String 
  description String
  location String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments EventAssignment[]
  dates EventDate[]

  setlistSongs SetlistSong[]
  messages Message[]


  createdById String
  createdBy User @relation(fields: [createdById], references: [id])

  serviceTypeId String
  serviceType ServiceType @relation(fields: [serviceTypeId], references: [id])

  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([serviceTypeId])
  @@index([organizationId])
}

model EventAssignment {
  id String @id @default(uuid())

  eventId String
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String
  user User @relation("assignedUser", fields: [userId], references: [id], onDelete: Cascade)

  assignedById String
  assignedBy User @relation("assignedBy", fields: [assignedById], references: [id])

  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  role VolunteerRole
  status InvitationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime

  @@unique([eventId, userId])
  @@index([organizationId])
  @@index([eventId])
  @@index([userId])
  @@index([status])

}

model EventDate {
  id  String @id @default(uuid())
  startTime DateTime
  endTime DateTime

  eventId String
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Message {
  id   String @id @default(uuid())
  body String

  eventId String
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  authorId String
  author   User @relation("authoredMessages", fields: [authorId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([eventId, createdAt])
  @@index([organizationId])
  @@index([authorId])
}

model Song {
  id String @id @default(uuid())
  title String
  artist String
  bpm Int
  timeSignature String
  defaultPitch Pitch?
  defaultKeyQuality KeyQuality?
  spotifyUrl String?
  youtubeUrl String?
  themes String[]

  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  setlistSongs SetlistSong[]


  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, title, artist])
  @@index([organizationId, deletedAt])

}

model SetlistSong {
  id String @id @default(uuid())
  pitch Pitch
  keyQuality KeyQuality
  bpm Int
  timeSignature String
  position Int

  eventId String
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  songId String
  song Song @relation(fields: [songId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, songId])
  @@index([eventId])
  @@index([songId])

}